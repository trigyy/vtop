{
  "manifest_version": 3,
  "name": "VTOP CGPA Hider",
  "description": "Automatically hides the CGPA and Credit Status section on VTOP so it never shows up. Works on all VIT campuses.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://vtop.vitbhopal.ac.in/*",
        "*://vtop.vit.ac.in/*",
        "*://vtopcc.vit.ac.in/*",
        "*://vtop.vitap.ac.in/*"
      ],
      "css": ["hide-cgpa.css"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://vtop.vitbhopal.ac.in/*",
        "*://vtop.vit.ac.in/*",
        "*://vtopcc.vit.ac.in/*",
        "*://vtop.vitap.ac.in/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
